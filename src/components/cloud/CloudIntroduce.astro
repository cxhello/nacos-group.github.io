    price: t("cloud.introduce.free.price"),
    unit: "",
    priceDesc: t("cloud.introduce.free.pkg"),
    linkName: t("cloud.introduce.learn.more"),
    link: "https://free.aliyun.com/?searchKey=nacos&spm=nacos.cloud.topbar.0.0.0",
    feature: [
      t("cloud.introduce.free.discount.1"),
      t("cloud.introduce.free.discount.2"),
    ],
  },
  {
    title: t("cloud.introduce.develop.pkg"),
    price: "¥82.6",
    priceDesc: t("cloud.introduce.develop.feature"),
    priceSupply: t('cloud.introduce.monthly_annual_supply'),
    unit: "/MONTH",
    payPrice: "¥0.252",
    payPriceSupply: t('cloud.introduce.pay_hour'),
    linkName: t("cloud.introduce.learn.more"),
    link: "https://www.aliyun.com/product/aliware/mse?spm=nacos.cloud.topbar.0.0.0",
    feature: [
      t("cloud.introduce.develop.discount.1"),
      t("cloud.introduce.develop.discount.2"),
    ],
    payFeature: [t("cloud.introduce.develop.discount.2")],
  },
  {
    title: t("cloud.introduce.regular.pkg"),
    priceDesc: t("cloud.introduce.regular.feature"),
    price: "¥298.8",
    priceSupply: t('cloud.introduce.monthly_annual_supply'),
    unit: "/MONTH",
    payPrice: "¥1.059",
    payPriceSupply: t('cloud.introduce.pay_hour'),
    linkName: t("cloud.introduce.learn.more"),
    link: "https://www.aliyun.com/product/aliware/mse?spm=nacos.cloud.topbar.0.0.0",
    feature: [
      t("cloud.introduce.regular.discount.1"),
      t("cloud.introduce.regular.discount.2"),
    ],
    payFeature: [t("cloud.introduce.regular.discount.2")],
  },
  {
    title: t("cloud.introduce.serverless.pkg"),
    priceDesc: t("cloud.introduce.serverless.feature"),
    price: "¥1086",
    priceSupply: t('cloud.introduce.monthly_annual_supply'),
    unit: "/HOUR",
    payPrice: "¥4.530",
    payPriceSupply: t('cloud.introduce.pay_hour'),
    linkName: t("cloud.introduce.learn.more"),
    link: "https://www.aliyun.com/product/aliware/mse?spm=nacos.cloud.topbar.0.0.0",
    feature: [
      t("cloud.introduce.serverless.discount.1"),
      t("cloud.introduce.serverless.discount.2"),
    ],
    payFeature: [t("cloud.introduce.serverless.discount.2")],
  },
];
const privateData = [
  {
    title: t("cloud.introduce.community.edition"),
    price: t("cloud.introduce.free.price"),
    unit: "",
    priceDesc: t("cloud.introduce.free.pkg"),
    linkName: t("cloud.introduce.learn.more"),
    link: "https://free.aliyun.com/?searchKey=nacos&spm=nacos.cloud.topbar.0.0.0",
    feature: [
      t("cloud.introduce.free.discount.1"),
      t("cloud.introduce.free.discount.2"),
    ],
  },
  {
    title: t('cloud.introduce.fly_unicorn'),
    price: t('cloud.introduce.premium'),
    unit: "",
    priceDesc: t('cloud.introduce.localization'),
    linkName: t("page.team.introduction.contact"),
    link: "https://survey.aliyun.com/apps/zhiliao/r4XOKJLjZ",
    feature: [
      t('cloud.introduce.performance_resource'),
      t('cloud.introduce.sla_guarantee'),
    ],
  },
];
---

<span class="cloud-introduce-div" id="cloud-introduce">
  <cloud-introduce
    class="cloud-introduce flex flex-col justify-center items-center pt-10 pb-14"
  >
    <BaseContainer class="top-introduce flex">
      <div class="left-section flex-1 flex flex-col">
        <h1 class="font-light pt-6 pb-4 text-gray-08 text-xs mt-[0]">
          {t("cloud.introduce.about")}
        </h1>
        <div
          class="title leading-[5rem] text-gray-03 mb-[1.1875rem] text-[4rem]"
        >
          {t("cloud.introduce.title")}
        </div>
        <span class="start-cloud text-gray-09 text-2xl"
          >{t("cloud.introduce.invite")}</span
        >
      </div>
    </BaseContainer>
    <div role="tablist" class="tabs tabs-boxed bg-transparent mt-9">
      <input
        type="radio"
        name="my_tabs_0"
        role="tab"
        class="tab primary-tab"
        aria-label={t('cloud.introduce.public')}
        checked="checked"
        data-type="public"
      />
      <div role="tabpanel" class="tab-content">
        <BaseContainer
          class="bottom-package flex justify-center mt-[2.9375rem]"
        >
          {
            introduceData.map((item, index) => {
              return (
                <div class="card-package cursor-pointer bg-gray-13 hover:border border-text-gray-06 rounded-2xl flex-1 text-center p-8">
                  <div class="package h-10">
                    <div class="title text-gray-03 text-2xl font-sans font-medium">
                      <span class="relative">
                        {item?.title}
                        {/* {index == 2 ? (
                          <span class="bg-[red] text-white absolute top-[-10px] right-[-40px] text-sm inline-block px-[5px] rounded-lg">HOT) : null} */}
                      </span>
                    </div>
                  </div>
                  {index > 0 && (
                    <div
                      role="tablist"
                      class="tabs tabs-boxed secondary-tabs bg-transparent mt-9 w-[152px] left-[50px]"
                    >
                      <input
                        type="radio"
                        name={`my_tabs_${index + 1}`}
                        role="tab"
                        class="tab secondary-tab text-[12px]"
                        aria-label={t('cloud.introduce.pay')}
                        checked="checked"
                      />
                      <div
                        role="tabpanel"
                        class="tab-content max-w-[328px] absolute left-[-85px] top-2"
                      >
                        <div class="price-content max-w-[328px] pt-4 border-b border-t border-gray-12 h-32">
                          <span class="price text-[2.75rem] leading-[3rem] font-bold text-gray-03">
                            {item?.payPrice}
                          </span>
                          <span class="price price_supply font-bold text-gray-08">
                            {item?.payPriceSupply}
                          </span>
                          <div class="description font-sans pt-4 text-xs text-gray-08 line-clamp-2">
                            {item?.priceDesc}
                          </div>
                        </div>
                        <div class="pl-2 h-16 flex justify-center flex-col items-center">
                          {item?.payFeature?.map((el, i) => {
                            return (
                              <div class="feature text-left text-xs text-gray-07 mt-4 line-clamp-2">
                                {el}
                              </div>
                            );
                          })}
                        </div>
                        <div class="subscribe text-center mt-6 mb-2">
                          <a
                            href={item?.link}
                            target="_blank"
                            name="introduce-data"
                          >
                            <button class="btn button-transform rounded-full w-full bg-gray-14 text-gray-03 hover:bg-gray-12">
                              {item?.linkName}
                            </button>
                          </a>
                        </div>
                      </div>
                      <input
                        type="radio"
                        name={`my_tabs_${index + 1}`}
                        role="tab"
                        class="tab secondary-tab text-[12px]"
                        aria-label={t('cloud.introduce.monthly_annual')}
                      />
                      <div
                        role="tabpanel"
                        class="tab-content max-w-[328px] absolute left-[-85px] top-2"
                      >
                        <div class="price-content max-w-[328px] pt-4 border-b border-t border-gray-12 h-32">
                          <span class="price text-[2.75rem] leading-[3rem] font-bold text-gray-03">
                            {item?.price}
                          </span>
                          <span class="price font-bold text-gray-08">
                            {item?.priceSupply}
                          </span>
                          <div class="description font-sans pt-4 text-xs text-gray-08 line-clamp-2">
                            {item?.priceDesc}
                          </div>
                        </div>
                        <div class="pl-2 h-16 flex justify-center flex-col items-center">
                          {item?.feature?.map((el, i) => {
                            return (
                              <div class="feature text-left text-xs text-gray-07 mt-4 line-clamp-2">
                                {el}
                              </div>
                            );
                          })}
                        </div>
                        <div class="subscribe text-center mt-6 mb-2">
                          <a
                            href={item?.link}
                            target="_blank"
                            name="introduce-data"
                          >
                            <button class="btn button-transform rounded-full w-full bg-gray-14 text-gray-03 hover:bg-gray-12">
                              {item?.linkName}
                            </button>
                          </a>
                        </div>
                      </div>
                    </div>
                  )}
                  {index == 0 && (
                    <div class="mt-11">
                      <div class="price-content pt-4 border-b border-t border-gray-12 h-32">
                        <span class="price text-[2.75rem] leading-[3rem] font-bold text-gray-03">
                          {item?.price}
                        </span>
                        <span class="price font-bold text-gray-08">
                          {item?.priceSupply}
                        </span>
                        <div class="description font-sans pt-4 text-xs text-gray-08 line-clamp-2">
                          {item?.priceDesc}
                        </div>
                      </div>
                      <div class="pl-2 h-16">
                        {item?.feature?.map((el, i) => {
                          return (
                            <div class="feature text-left text-xs text-gray-07 mt-4 line-clamp-2">
                              {el}
                            </div>
                          );
                        })}
                      </div>
                      <div class="subscribe text-center mt-6 mb-2">
                        <a
                          href={item?.link}
                          target="_blank"
                          name="introduce-data"
                        >
                          <button class="btn button-transform rounded-full w-full bg-gray-14 text-gray-03 hover:bg-gray-12">
                            {item?.linkName}
                          </button>
                        </a>
                      </div>
                    </div>
                  )}
                </div>
              );
            })
          }
        </BaseContainer>
      </div>
      <input
        type="radio"
        name="my_tabs_0"
        role="tab"
        class="tab primary-tab"
        aria-label={t("cloud.introduce.private")}
        data-type="private"
      />
      <div role="tabpanel" class="tab-content">
        <BaseContainer
          class="bottom-package flex justify-center mt-[2.9375rem]"
        >
          {
            privateData.map((item, index) => {
              return (
                <div class="card-package cursor-pointer bg-gray-14 border-[.0313rem] max-w-[328px] hover:border border-text-gray-06 rounded-2xl flex-1 text-center p-8">
                  <div class="package h-16">
                    <div class="title text-gray-03 text-2xl font-sans font-medium">
                      <span class="relative">
                        {item?.title}
                        {index == 2 ? (
                          <span class="bg-[red] text-white absolute top-[-10px] right-[-40px] text-sm inline-block px-[5px] rounded-lg">
                            HOT
                          </span>
                        ) : null}
                      </span>
                    </div>
                  </div>
                  <div class="price-content pt-4 border-b border-t border-gray-12 h-32">
                    <span class="price text-[2.75rem] leading-[3rem] font-bold text-gray-03">
                      {item?.price}
                    </span>
                    <div class="description font-sans pt-4 text-xs text-gray-08 line-clamp-2">
                      {item?.priceDesc}
                    </div>
                  </div>
                  <div class="pl-2 h-16">
                    {item?.feature?.map((el, i) => {
                      return (
                        <div class="feature text-left text-xs text-gray-07 mt-4 line-clamp-2">
                          {el}
                        </div>
                      );
                    })}
                  </div>
                  <div class="subscribe text-center mt-6 mb-2">
                    <a href={item?.link} target="_blank" name="introduce-data">
                      <button class="btn button-transform rounded-full w-full bg-gray-14 text-gray-03 hover:bg-gray-12">
                        {item?.linkName}
                      </button>
                    </a>
                  </div>
                </div>
              );
            })
          }
        </BaseContainer>
      </div>
    </div>
  </cloud-introduce>
</span>
<script>
  function replaceUrl(document) {
    if (window.location.search && document.getElementById("cloud-introduce")) {
      const params = new URLSearchParams(window.location.search);
      const fromParams = params.get("from");
      if (fromParams === "wuyi") {
        const linkElements = document.getElementsByName("introduce-data");

        // 注意： 当前链接为硬编码，后续需要根据需求进行修改
        linkElements[0].href =
          "https://free.aliyun.com/?searchKey=nacos&spm=nacos.sx.topbar.1.1.1";
        linkElements[1].href =
          "https://www.aliyun.com/product/aliware/mse?spm=nacos.sx.topbar.0.0.0";
        linkElements[2].href =
          "https://www.aliyun.com/product/aliware/mse?spm=nacos.sx.topbar.0.0.0";
        linkElements[3].href =
          "https://www.aliyun.com/product/aliware/mse?spm=nacos.sx.topbar.0.0.0";
      }
    }
  }
  window.addEventListener("DOMContentLoaded", () => {
    replaceUrl(document);
  });
  document.addEventListener("astro:before-swap", (ev) => {
    replaceUrl(ev.newDocument);
  });
  // 监听标签页切换
  document.addEventListener("DOMContentLoaded", () => {
    const tabInputs = document.querySelectorAll('input[name="my_tabs_0"]');

    tabInputs.forEach((input) => {
      input.addEventListener("change", (e) => {
        const target = e.target as HTMLInputElement;
        if (target.checked) {
          const tabType = target.dataset.type;
          // 发送自定义事件到 FunctionalCompare
          window.dispatchEvent(
            new CustomEvent("tabChange", {
              detail: { tabType },
            }),
          );
        }
      });
    });
  });
</script>

<style is:global>
  .cloud-introduce-div {
    .cloud-introduce {
      background-color: theme("colors.gray.14");
      background-image: url("https://img.alicdn.com/imgextra/i3/O1CN01WdSy2u1glrf0I5cXJ_!!6000000004183-2-tps-2400-2400.png"); /* 设置背景图片 */
      background-repeat: no-repeat;
      background-position: right;
      background-size: 70%;
    }
    .tab-content {
      width: 1392px;
      padding-left: 16px;
    }
    .tab:is(input[type="radio"]) {
      width: 80px;
      border-radius: 20px;
      color: theme("colors.gray.06");
    }
    .tabs-boxed .tab-active:not(.tab-disabled):not([disabled]),
    .primary-tab:checked {
      background-color: theme("colors.blue.01");
      color: theme("colors.gray.14") !important;
    }
    .secondary-tab:checked {
      background-color: theme("colors.gray.12");
      color: theme("colors.gray.01") !important;
    }
    .tabs {
      position: relative;
      margin-top: 4px;
    }
    .tabs::before {
      content: "";
      position: absolute;
      top: 0px;
      left: 0px;
      width: 168px;
      height: 40px;
      background-color: theme("colors.gray.13");
      pointer-events: none;
      border-radius: 20px;
    }
    .secondary-tabs::before {
      content: "";
      position: absolute;
      top: 0px;
      left: 0px;
      width: 168px;
      height: 40px;
      background-color: theme("colors.gray.14");
      pointer-events: none;
      border-radius: 20px;
    }
    .card-package {
      flex: 1;
      margin: 0 0.5rem;
      transition:
        transform 0.2s,
        box-shadow 0.2s;
    }
    .card-package:hover {
      transition:
        transform 0.2s,
        box-shadow 0.2s;
      transform: translateY(-4px);
      box-shadow:
        4px 4px 8px rgba(0, 0, 0, 0.1),
        -4px -4px 8px rgba(0, 0, 0, 0.1);
    }
    .bottom-package .card-package:first-child {
      margin-left: 0;
      /* background-color: theme("colors.blue.01"); */
    }
    .bottom-package .card-package:nth-child(1) {
      background-color: theme("colors.blue.01");
    }

    .bottom-package .card-package:nth-child(1) .package .title {
      color: theme("colors.gray.14");
    }
    .bottom-package .card-package:nth-child(1) .price-content {
      border-color: theme("colors.gray.03");
    }
    .bottom-package .card-package:nth-child(1) .price-content .price {
      color: theme("colors.gray.14");
    }
    .bottom-package .card-package:nth-child(1) .price-content .description {
      color: theme("colors.gray.14");
    }
    .bottom-package .card-package:nth-child(1) .feature {
      color: theme("colors.gray.08");
    }
    .bottom-package .card-package:last-child {
      margin-right: 0;
    }
    .button-transform {
      display: inline-block;
      vertical-align: middle;
      -webkit-transform: perspective(1px) translateZ(0);
      transform: perspective(1px) translateZ(0);
      box-shadow: 0 0 1px rgba(0, 0, 0, 0);
      -webkit-transition-duration: 0.3s;
      transition-duration: 0.3s;
      -webkit-transition-property: box-shadow, transform;
      transition-property: box-shadow, transform;
      transition: background-color 0.5s ease;
    }

    .bottom-package
      .card-package:nth-child(1)
      .subscribe
      .button-transform:hover {
      color: theme("colors.gray.03");
      background: linear-gradient(226deg, #2c46c9 -2%, rgba(0, 0, 0, 0) 43%),
        #121316;
    }

    .button-transform:hover {
      color: theme("colors.gray.13");
      background-color: theme("colors.gray.01");
    }
    /* 小于50rem  小于 800px */
    @media (max-width: 50rem) {
      .cloud-introduce {
        padding: 1.5rem;
      }
      .tab-content {
        /* width: 100%; */
        max-width: 328px;
      }
      .top-introduce {
        width: 100%;
      }
      .top-introduce .left-section .title {
        font-size: 1.875rem;
        line-height: 2.25rem;
      }
      .top-introduce .left-section .start-cloud {
        font-size: 1.125rem; /* 18px */
        line-height: 1.75rem; /* 28px */
      }
      .top-introduce .right-section {
        display: none;
      }
      .bottom-package {
        width: 100%;
        flex-wrap: wrap;
      }
      .bottom-package .card-package {
        padding: 1.5rem;
        flex: 0 0 100%;
        margin: 0 0 1rem 0;
      }
      .bottom-package .card-package:last-child {
        margin-bottom: 0;
      }
      .card-package {
        height: 398px;
      }

      /* 手机端卡片样式单独设置 */
      .price-content .price {
        font-size: 1.875rem; /* 30px */
        line-height: 2.25rem; /* 36px */
      }
      .price_supply {
        font-size: 14px !important;
        font-weight: normal;
      }
      .subscribe {
        margin-bottom: 0;
      }
      .subscribe .button-transform {
        height: 2rem;
        min-height: 2rem;
        padding-left: 0.75rem;
        padding-right: 0.75rem;
      }
    }

    /* 大于50rem 小于 72rem  800px < width < 1152 */
    @media (min-width: 50rem) and (max-width: 86rem) {
      .cloud-introduce {
        padding: 2.5rem;
      }
      .tab-content {
        width: 100%;
      }
      .top-introduce {
        width: 100%;
      }
      .bottom-package {
        width: 100%;
        flex-wrap: wrap;
      }
      .bottom-package .card-package {
        flex: 0 0 40%;
        margin: 0 0.5rem 1rem 0.5rem;
      }
      .bottom-package .card-package:first-child {
        margin-left: 0.5rem;
      }
      .bottom-package .card-package:last-child {
        margin-right: 0.5rem;
      }
    }
  }
</style>
